# ─── App ──────────────────────
APP_NAME=Homiq
APP_VERSION=1.0.0
DEBUG=true

# ─── Database ─────────────────
DATABASE_URL=postgresql+asyncpg://homiq:homiq_secret@localhost:5432/homiq

# ─── Redis ────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT ──────────────────────
SECRET_KEY=change-this-to-a-very-long-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── MinIO ────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=homiq_minio
MINIO_SECRET_KEY=homiq_minio_secret
MINIO_BUCKET_NAME=homiq-assets
MINIO_SECURE=false

# ─── Celery ───────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── CORS ─────────────────────
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
